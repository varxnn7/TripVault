rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the caller is the designated admin
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if caller is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // ---- Users collection ----
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());

      match /trips/{tripId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        match /{sub}/{docId} {
          allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        }
      }

      // Legacy issues subcollection (kept in case any old data exists)
      match /issues/{issueId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        match /comments/{commentId} {
          allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        }
      }
    }

    // ---- Top-level support_tickets collection ----
    match /support_tickets/{ticketId} {
      // Any authenticated user can create a ticket (must include their own userId)
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Owner can read their own tickets; admin reads all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Owner or admin can update a ticket (status changes, etc.)
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      // Comments on a ticket — any authenticated user can read/write
      // (the ticketId is a secret known only to the ticket owner and admin)
      match /comments/{commentId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
